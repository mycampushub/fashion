{
  "name": "fashion",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "build:cloudflare": "npx opennextjs-cloudflare build --packager npm",
    "copy:public": "node scripts/copy-public-assets.js",
    "copy:public:win": "scripts\\copy-public-assets.bat",
    "copy:public:ps": "powershell -ExecutionPolicy Bypass -File scripts/copy-public-assets.ps1",
    "build:workers": "npm run build && npm run build:cloudflare",
    "start": "NODE_ENV=production node .next/standalone/server.js 2>&1 | tee server.log",
    "predeploy": "npm install --no-frozen-lockfile",
    "install:ci": "npm install --no-frozen-lockfile",
    "lint": "eslint src/",
    "warm-cache": "bun scripts/warm-cache.ts",
    "invalidate-cache": "bun scripts/invalidate-cache.ts",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:seed": "bun scripts/seed-db.ts",
    "db:setup": "wrangler d1 execute fashion-db --file=db/schema.sql",
    "db:setup:remote": "wrangler d1 execute fashion-db --remote --file=db/schema.sql",
    "db:seed:d1": "wrangler d1 execute fashion-db --file=db/seed.sql",
    "db:seed:d1:remote": "wrangler d1 execute fashion-db --remote --file=db/seed.sql",
    "db:migrate:color-images": "wrangler d1 execute fashion-db --file=db/migrations/add-product-color-images.sql",
    "db:migrate:color-images:remote": "wrangler d1 execute fashion-db --remote --file=db/migrations/add-product-material-color.sql",
    "deploy:workers": "npm run build:cloudflare && npm run copy:public && wrangler deploy",
    "deploy:pages": "npm run build:cloudflare && npm run copy:public && wrangler pages deploy .open-next/assets",
    "test:api": "node scripts/test-apis.js",
    "test:api:bun": "bun scripts/test-apis.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:unit": "vitest src/__tests__/unit",
    "test:integration": "vitest src/__tests__/integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1053.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.1.1",
    "@prisma/client": "^6.19.3",
