generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model HomepageSettings {
  id           String   @id
  sectionName  String   @unique
  isEnabled    Int      @default(1)
  autoPlay     Int      @default(5000)
  displayLimit Int?
  settings     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now())

  @@map("homepage_settings")
}

model addresses {
  id           String   @id
  userId       String
  fullName     String
  phone        String
  addressLine1 String
  addressLine2 String?
  city         String
  district     String?
  division     String
  postalCode   String?
  isDefault    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime
  users        users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isDefault])
  @@index([userId])
}

model admin_logs {
  id        String   @id
  action    String
  entity    String
  entityId  String?
  adminId   String
  details   String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  users     users    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([entity, entityId])
  @@index([createdAt(sort: Desc)])
  @@index([action, createdAt(sort: Desc)])
  @@index([entity, createdAt(sort: Desc)])
  @@index([adminId, createdAt(sort: Desc)])
}

model analytics_integrations {
  id            String   @id
  name          String   @unique
  provider      String   @default("custom")
  trackingId    String?
  measurementId String?
  apiKey        String?
  pixelId       String?
  isActive      Boolean  @default(true)
  settings      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime
}

model banners {
  id          String   @id
  title       String
  description String?
  image       String
  mobileImage String?
  buttonText  String?
  buttonLink  String?
  isActive    Int      @default(1)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@index([order])
  @@index([isActive])
}

model brands {
  id          String   @id
  name        String   @unique
  slug        String   @unique
  logo        String?
  website     String?
  description String?
  country     String?
  isActive    Int      @default(1)
  featured    Int      @default(0)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime

  @@index([isActive, sortOrder])
  @@index([featured])
  @@index([slug])
}

model cart_items {
  id               String            @id
  userId           String
  productId        String
  variantId        String?
  quantity         Int               @default(1)
  version          Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime
  product_variants product_variants? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  products         products          @relation(fields: [productId], references: [id], onDelete: Cascade)
  users            users             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId, variantId])
  @@index([variantId])
  @@index([userId, variantId])
  @@index([userId])
}

model categories {
  id          String       @id
  name        String       @unique
  slug        String       @unique
  description String?
  image       String?
  parentId    String?
  sortOrder   Int          @default(0)
  isActive    Int          @default(1)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime
  parent      categories?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    categories[] @relation("CategoryHierarchy")
  products    products[]

  @@index([isActive])
  @@index([slug])
  @@index([parentId])
  @@index([isActive, sortOrder])
}

model email_services {
  id          String    @id
  name        String    @unique
  provider    String    @default("custom")
  apiKey      String?
  apiSecret   String?
  fromEmail   String?
  fromName    String?
  webhookUrl  String?
  sandboxMode Int       @default(0)
  isActive    Boolean   @default(true)
  isDefault   Boolean   @default(false)
  settings    String?
  lastTested  DateTime?
  testStatus  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
}

model inventory_alerts {
  id               String            @id
  variantId        String?
  productId        String?
  alertType        String            @default("LOW_STOCK")
  quantity         Int
  isRead           Int               @default(0)
  isResolved       Int               @default(0)
  resolvedAt       DateTime?
  createdAt        DateTime          @default(now())
  products         products?         @relation(fields: [productId], references: [id], onDelete: Cascade)
  product_variants product_variants? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([productId, variantId, alertType], name: "unique_product_variant_alert")
  @@index([isRead, isResolved])
  @@index([productId])
  @@index([variantId])
}

model inventory_reservations {
  id               String            @id
  variantId        String?
  productId        String?
  userId           String
  quantity         Int
  expiresAt        DateTime
  createdAt        DateTime          @default(now())
  products         products?         @relation(fields: [productId], references: [id], onDelete: Cascade)
  product_variants product_variants? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([userId])
  @@index([productId])
  @@index([variantId])
}

model order_items {
  id               String            @id
  orderId          String
  productId        String
  variantId        String?
  quantity         Int
  price            Decimal
  productName      String
  productImage     String?
  variantSku       String?
  variantSize      String?
  variantColor     String?
  variantMaterial  String?
  createdAt        DateTime          @default(now())
  product_variants product_variants? @relation(fields: [variantId], references: [id])
  products         products          @relation(fields: [productId], references: [id])
  orders           orders            @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@index([productId])
  @@index([orderId])
}

model orders {
  id                    String        @id
  orderNumber           String        @unique
  userId                String?
  customerName          String
  customerEmail         String
  customerPhone         String?
  shippingAddress       String
  billingAddress        String?
  city                  String?
  district              String?
  division              String?
  subtotal              Decimal
  shipping              Decimal       @default(0)
  tax                   Decimal       @default(0)
  discount              Decimal       @default(0)
  total                 Decimal
  status                String        @default("PENDING")
  paymentStatus         String        @default("PENDING")
  paymentMethod         String?
  trackingNumber        String?
  trackingStatus        String        @default("PENDING")
  estimatedDeliveryDate String?
  cancelledAt           String?
  cancelledBy           String?
  cancellationReason    String?
  refundedAt            String?
  refundedAmount        Decimal?
  refundMethod          String?
  refundReason          String?
  notes                 String?
  deletedAt             DateTime?
  deletedBy             String?
  deletedReason         String?
  version               Int           @default(0)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime
  promoCode             String?
  order_items           order_items[]
  users                 users?        @relation(fields: [userId], references: [id])

  @@index([deletedAt])
  @@index([customerEmail, status])
  @@index([status, createdAt(sort: Desc)])
  @@index([orderNumber])
  @@index([customerEmail])
  @@index([userId])
}

model payment_gateways {
  id                  String    @id
  name                String    @unique
  provider            String    @default("custom")
  apiKey              String?
  apiSecret           String?
  webhookUrl          String?
  webhookSecret       String?
  sandboxMode         Int       @default(0)
  supportedCurrencies String?
  isActive            Boolean   @default(true)
  isDefault           Boolean   @default(false)
  settings            String?
  lastTested          DateTime?
  testStatus          String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime
}

model posts {
  id        String   @id
  title     String
  content   String?
  published Int      @default(0)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime
  users     users    @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
}

model product_reviews {
  id         String   @id
  productId  String
  userId     String
  userName   String?
  rating     Int
  title      String?
  comment    String?
  isVerified Int      @default(0)
  isApproved Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime
  users      users    @relation(fields: [userId], references: [id], onDelete: Cascade)
  products   products @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, userId])
  @@index([isApproved, createdAt(sort: Desc)])
  @@index([userId])
  @@index([productId, rating(sort: Desc)])
  @@index([productId, isApproved])
}

model product_variants {
  id                     String                   @id
  productId              String
  sku                    String                   @unique
  name                   String
  price                  Decimal
  comparePrice           Decimal?
  stock                  Int                      @default(0)
  images                 String?
  size                   String?
  color                  String?
  material               String?
  isActive               Int                      @default(1)
  isDefault              Int                      @default(0)
  lowStockAlert          Int                      @default(10)
  reorderLevel           Int                      @default(5)
  reorderQty             Int                      @default(20)
  version                Int                      @default(0)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime
  costPrice              Decimal?                 @default(0)
  sizeType               String?
  sizeValue              Float?
  sizeUnit               String?
  sizeLabel              String?
  countryOfOrigin        String?
  totalPurchased         Int                      @default(0)
  totalSold              Int                      @default(0)
  totalCost              Decimal?                 @default(0)
  averageCost            Decimal?                 @default(0)
  cart_items             cart_items[]
  inventory_adjustments  inventory_adjustments[]
  inventory_alerts       inventory_alerts[]
  inventory_movements    inventory_movements[]
  inventory_reservations inventory_reservations[]
  order_items            order_items[]
  products               products                 @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, size, color])
  @@index([productId, isActive])
  @@index([sku])
  @@index([productId])
  @@index([countryOfOrigin])
  @@index([sizeType, sizeUnit])
}

model products {
  id                     String                   @id
  name                   String
  slug                   String                   @unique
  description            String?
  categoryId             String
  price                  Decimal                  @default(0)
  basePrice              Decimal                  @default(0)
  comparePrice           Decimal?
  discount               Decimal                  @default(0)
  discountType           String                   @default("percentage")
  images                 String?
  stock                  Int                      @default(0)
  lowStockAlert          Int                      @default(10)
  reorderLevel           Int                      @default(5)
  reorderQty             Int                      @default(20)
  isActive               Int                      @default(1)
  isFeatured             Int                      @default(0)
  hasVariants            Int                      @default(0)
  weight                 Float?
  dimensions             String?
  tags                   String?
  version                Int                      @default(0)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime
  costPrice              Decimal?                 @default(0)
  brandId                String?
  brandName              String?
  brandLogo              String?
  sizeType               String?
  sizeValue              Float?
  sizeUnit               String?
  sizeLabel              String?
  material               String?
  color                  String?
  countryOfOrigin        String?
  availableSizes         String?
  availableColors        String?
  totalPurchased         Int                      @default(0)
  totalSold              Int                      @default(0)
  totalCost              Decimal?                 @default(0)
  averageCost            Decimal?                 @default(0)
  lastPurchaseAt         DateTime?
  lastPurchaseCost       Decimal?
  cart_items             cart_items[]
  inventory_adjustments  inventory_adjustments[]
  inventory_alerts       inventory_alerts[]
  inventory_movements    inventory_movements[]
  inventory_reservations inventory_reservations[]
  order_items            order_items[]
  product_color_images   product_color_images[]
  product_reviews        product_reviews[]
  product_variants       product_variants[]
  categories             categories               @relation(fields: [categoryId], references: [id])
  wishlist_items         wishlist_items[]

  @@index([isActive, isFeatured])
  @@index([slug])
  @@index([isActive, createdAt(sort: Desc)])
  @@index([isFeatured])
  @@index([categoryId])
  @@index([brandId])
  @@index([countryOfOrigin])
  @@index([sizeType, sizeUnit])
}

model product_color_images {
  id        String   @id
  productId String
  color     String
  images    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  products  products @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, color])
  @@index([productId])
  @@index([color])
}

model promotions {
  id                   String    @id
  title                String
  description          String?
  image                String?
  ctaText              String?
  ctaLink              String?
  type                 String    @default("banner")
  promoCode            String?   @unique
  discountType         String?
  discountValue        Decimal?
  minOrderAmount       Decimal?
  maxDiscountAmount    Decimal?
  startDate            DateTime?
  endDate              DateTime?
  usageLimit           Int?
  usedCount            Int       @default(0)
  userLimit            Int?
  applicableCategories String?
  applicableProducts   String?
  conditions           String?
  discountRules        String?
  isActive             Int       @default(1)
  order                Int       @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime

  @@index([promoCode])
  @@index([type, isActive])
  @@index([isActive])
}

model reels {
  id         String   @id
  title      String
  thumbnail  String
  videoUrl   String
  productIds String?
  isActive   Int      @default(1)
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime

  @@index([order])
  @@index([isActive])
}

model shipping_carriers {
  id              String    @id
  name            String    @unique
  provider        String    @default("custom")
  apiKey          String?
  apiSecret       String?
  accountNumber   String?
  webhookUrl      String?
  sandboxMode     Int       @default(0)
  shippingMethods String?
  isActive        Boolean   @default(true)
  isDefault       Boolean   @default(false)
  settings        String?
  lastTested      DateTime?
  testStatus      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime
}

model site_settings {
  id                    String   @id
  siteName              String   @default("SCommerce")
  siteLogo              String?
  currency              String   @default("BDT")
  currencySymbol        String   @default("৳")
  taxRate               Decimal  @default(0.18)
  freeShippingThreshold Decimal  @default(5000)
  baseShippingCost      Decimal  @default(150)
  contactEmail          String?
  contactPhone          String?
  socialMedia           String?
  enableStore           Int      @default(1)
  maintenanceMode       Int      @default(0)
  seo                   String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime
}

model stories {
  id        String   @id
  title     String
  thumbnail String
  images    String
  isActive  Int      @default(1)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime

  @@index([order])
  @@index([isActive])
}

model users {
  id               String            @id
  email            String            @unique
  name             String?
  phone            String?           @unique
  address          String?
  password         String?
  emailVerified    Int               @default(0)
  emailToken       String?
  newEmail         String?
  resetToken       String?
  resetTokenExpiry String?
  role             String            @default("user")
  avatar           String?
  isBanned         Boolean           @default(false)
  bannedAt         DateTime?
  lastLoginAt      DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime
  addresses        addresses[]
  admin_logs       admin_logs[]
  cart_items       cart_items[]
  orders           orders[]
  posts            posts[]
  product_reviews  product_reviews[]
  wishlist_items   wishlist_items[]
}

model wishlist_items {
  id        String   @id
  userId    String
  productId String
  createdAt DateTime @default(now())
  products  products @relation(fields: [productId], references: [id], onDelete: Cascade)
  users     users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model media {
  id           String   @id
  filename     String
  originalName String
  url          String   @unique
  mimeType     String
  size         Int
  width        Int?
  height       Int?
  alt          String?
  tags         String?
  category     String?
  uploadedBy   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([category])
  @@index([createdAt(sort: Desc)])
  @@index([uploadedBy])
}

model suppliers {
  id                 String                @id
  code               String                @unique
  name               String
  email              String?
  phone              String?
  address            String?
  city               String?
  country            String?
  isActive           Int                   @default(1)
  notes              String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime
  inventoryMovements inventory_movements[]
  purchaseOrders     purchase_orders[]

  @@index([isActive])
  @@index([code])
}

model purchase_orders {
  id            String                 @id
  orderNumber   String                 @unique
  supplierId    String
  status        String                 @default("PENDING")
  totalAmount   Decimal
  totalQuantity Int
  orderDate     DateTime
  expectedDate  DateTime?
  receivedDate  DateTime?
  notes         String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime
  items         purchase_order_items[]
  supplier      suppliers              @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@index([status, orderDate])
  @@index([orderDate(sort: Desc)])
}

model purchase_order_items {
  id              String          @id
  purchaseOrderId String
  productId       String
  variantId       String?
  quantity        Int
  unitCost        Decimal
  totalCost       Decimal
  receivedQty     Int             @default(0)
  createdAt       DateTime        @default(now())
  purchaseOrder   purchase_orders @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([productId])
  @@index([variantId])
}

model inventory_movements {
  id            String            @id
  productId     String?
  variantId     String?
  movementType  String
  quantity      Int
  unitCost      Decimal?
  totalCost     Decimal?
  referenceId   String?
  referenceType String?
  approved      Int               @default(0)
  approvedAt    DateTime?
  supplierId    String?
  notes         String?
  createdAt     DateTime          @default(now())
  variant       product_variants? @relation(fields: [variantId], references: [id])
  product       products?         @relation(fields: [productId], references: [id])
  supplier      suppliers?        @relation(fields: [supplierId], references: [id])

  @@index([productId, createdAt])
  @@index([variantId, createdAt])
  @@index([movementType, createdAt])
  @@index([referenceId, referenceType])
  @@index([createdAt(sort: Desc)])
  @@index([supplierId])
}

model inventory_adjustments {
  id             String            @id
  productId      String?
  variantId      String?
  adjustmentType String
  quantityBefore Int
  quantityAfter  Int
  quantityDiff   Int
  reason         String
  approvedBy     String?
  approved       Int               @default(0)
  approvedAt     DateTime?
  notes          String?
  createdAt      DateTime          @default(now())
  variant        product_variants? @relation(fields: [variantId], references: [id])
  product        products?         @relation(fields: [productId], references: [id])

  @@index([productId, createdAt])
  @@index([adjustmentType, createdAt])
  @@index([createdAt(sort: Desc)])
}

model page_seo {
  id               String   @id
  pagePath         String   @unique
  pageTitle        String?
  metaTitle        String?
  metaDescription  String?
  keywords         String?
  ogTitle          String?
  ogDescription    String?
  ogImage          String?
  canonicalUrl     String?
  robots           String?  @default("index, follow")
  isActive         Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([pagePath])
  @@index([isActive])
}
